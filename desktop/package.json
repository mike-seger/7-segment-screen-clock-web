{
  "name": "7-segment-screen-clock-desktop",
  "version": "1.0.0",
  "description": "7-segment screen clock desktop app with built-in UDP discovery/presence and status server",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "package": "electron-builder",
    "package:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.7segmentclock.desktop",
    "productName": "7-Segment Clock",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../web",
        "to": "web",
        "filter": ["**/*"]
      },
      {
        "from": "../mobile/wv-clock/app/src/main/assets/remote-bridge.js",
        "to": "remote-bridge.js"
      }
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64"]
        }
      ]
    }
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "ip": "^1.1.9"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
